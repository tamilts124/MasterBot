  [Tool Call]: write_file({'file_path': 'src/components/state_manager.py', 'text': '"""\nState Management System\n=======================\n\nThis module acts as the central hub (Integration Bridge) connecting the \ndata parsing layer to the UI components. It manages the application state,\nhandles data consolidation, and provides a reactive-like interface for \nUI components to access processed data.\n"""\n\nimport pandas as pd\nimport numpy as np\nfrom typing import Dict, Any, List, Optional, Callable\nfrom dataclasses import dataclass, field\nfrom datetime import datetime\nfrom .components.data_parser.csv_parser import CSVParser\nfrom .components.data_parser.json_parser import JSONParser\nfrom .components.data_parser.exceptions import DataParserError\n\n@dataclass\nclass AppState:\n    """Holds the current state of the application."""\n    data: pd.DataFrame = field(default_factory=lambda: pd.DataFrame())\n    metadata: Dict[str, Any] = field(default_factory=dict)\n    is_loading: bool = False\n    last_updated: Optional[datetime] = None\n    errors: List[str] = field(default_factory=list)\n    warnings: List[str] = field(default_factory=list)\n    active_filters: Dict[str, Any] = field(default_factory=dict)\n\nclass StateManager:\n    """\n    The Integration Bridge that manages state and coordinates between \n    the data parser and the UI.\n    """\n    \n    def __init__(self):\n        self._state = AppState()\n        self._listeners: List[Callable[[AppState], None]] = []\n        self._csv_parser = CSVParser()\n        self._json_parser = JSONParser()\n\n    def subscribe(self, callback: Callable[[AppState], None]):\n        """Subscribe to state changes."""\n        self._listeners.append(callback)\n\n    def _notify_listeners(self):\n        """Notify all subscribers that the state has changed."""\n        for callback in self._listeners:\n            callback(self._state)\n\n    def get_state(self) -> AppState:\n        """Return the current state."""\n        return self._state\n\n    def set_loading(self, loading: bool):\n        """Update loading state."""\n        self._state.is_loading = loading\n        self._notify_listeners()\n\n    def load_data(self, source: str, file_type: str, **kwargs):\n        """\n        Bridge method to load data from a source and update the state.\n        \n        Parameters:\n        -----------\n        source : str\n            Path to the data file.\n        file_type : str\n            \'csv\' or \'json\'.\n        **kwargs : \n            Additional arguments passed to the respective parser.\n        """\n        self.set_loading(True)\n        self._state.errors = []\n        self._state.warnings = []\n\n        try:\n            if file_type.lower() == \'csv\':\n                df = self._csv_parser.parse(source, **kwargs)\n                self._state.warnings.extend(self._csv_parser.get_warnings())\n            elif file_type.lower() == \'json\':\n                df = self._json_parser.parse(source, **kwargs)\n                self._state.warnings.extend(self._json_parser.get_warnings())\n            else:\n                raise DataParserError(f"Unsupported file type: {file_type}")\n\n            # Final Consolidation: Standardize and store the data\n            self._consolidate_data(df)\n            self._state.last_updated = datetime.now()\n            \n        except DataParserError as e:\n            self._state.errors.append(str(e))\n        except Exception as e:\n            self._state.errors.append(f"Unexpected error: {str(e)}")\n        finally:\n            self.set_loading(False)\n\n    def _consolidate_data(self, df: pd.DataFrame):\n        """\n        Performs final consolidation and cleaning before updating state.\n        This is where business logic for data merging or final \n        transformations would live.\n        """\n        # Example consolidation: Ensure all column names are lowercase and stripped\n        df.columns = [str(col).strip().lower() for col in df.columns]\n        \n        # Store in state\n        self._state.data = df\n        \n        # Update metadata\n        self._state.metadata = {\n            "row_count": len(df),\n            "col_count": len(df.columns),\n            "columns": df.columns.tolist(),\n            "memory_usage": df.memory_usage(deep=True).sum()\n        }\n        \n        self._notify_listeners()\n\n    def apply_filter(self, column: str, value: Any):\n        """Apply a filter to the current data state."""\n        if column not in self._state.data.columns:\n            self._state.errors.append(f"Column {column} not found for filtering")\n            self._notify_listeners()\n            return\n\n        self._state.active_filters[column] = value\n        self._notify_listeners()\n\n    def get_filtered_data(self) -> pd.DataFrame:\n        """Return data filtered by the current active filters."""\n        df = self._state.data.copy()\n        for col, val in self._state.active_filters.items():\n            df = df[df[col] == val]\n        return df\n\n    def clear_state(self):\n        """Reset the application state."""\n        self._state = AppState()\n        self._notify_listeners()\n'})
