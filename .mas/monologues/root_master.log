  [Tool Call]: write_file({'file_path': 'src/components/ui/dashboard_view.py', 'text': '"""\nDashboard View Component\n========================\n\nA mock UI component that demonstrates how to interact with the StateManager.\nIn a real application, this would be a React/Vue component or a Tkinter/PyQt window.\n"""\n\nfrom typing import Any\nfrom ..state_manager import StateManager, AppState\n\nclass DashboardView:\n    """\n    Represents the UI layer of the application.\n    It subscribes to the StateManager and updates its \'view\' when state changes.\n    """\n    \n    def __init__(self, state_manager: StateManager):\n        self.state_manager = state_manager\n        # Subscribe to state changes\n        self.state_manager.subscribe(self.render)\n        self.current_view_data = None\n\n    def render(self, state: AppState):\n        """\n        Simulates rendering the UI based on the current state.\n        """\n        print("\\n--- UI RENDER START ---")\n        if state.is_loading:\n            print("[UI] Loading data... Please wait.")\n        \n        if state.errors:\n            print(f"[UI] ERRORS DETECTED: {state.errors}")\n            \n        if state.warnings:\n            print(f"[UI] WARNINGS: {state.warnings}")\n\n        if not state.data.empty:\n            print(f"[UI] Displaying Data: {state.metadata[\'row_count\']} rows, {state.metadata[\'col_count\']} columns")\n            print(f"[UI] Last Updated: {state.last_updated}")\n            # Show first 5 rows of the current state\n            print(state.data.head().to_string())\n        else:\n            print("[UI] No data available to display.")\n            \n        if state.active_filters:\n            print(f"[UI] Active Filters: {state.active_filters}")\n            \n        print("--- UI RENDER END ---\\n")\n\n    def trigger_load_csv(self, path: str):\n        print(f"[UI] User clicked \'Load CSV\' for {path}")\n        self.state_manager.load_data(path, \'csv\')\n\n    def trigger_load_json(self, path: str):\n        print(f"[UI] User clicked \'Load JSON\' for {path}")\n        self.state_manager.load_data(path, \'json\')\n\n    def trigger_filter(self, column: str, value: Any):\n        print(f"[UI] User applied filter: {column} == {value}")\n        self.state_manager.apply_filter(column, value)\n'})
